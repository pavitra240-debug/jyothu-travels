# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://your_username:your_password@cluster.xxxxx.mongodb.net/?appName=Cluster0

# Server Port
PORT=5000

# JWT Secret - Change this to a long random string in production
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345

# Frontend URL (for CORS)
# During development: http://localhost:5173
# In production: your_domain.com or https://your_domain.com
FRONTEND_URL=http://localhost:5173

# Email Notifications (Nodemailer config for bookings and contact form)
# EMAIL_USER=your_gmail_address@gmail.com
# EMAIL_PASS=your_gmail_app_password

# Environment
# Set to 'production' when deploying
NODE_ENV=development
