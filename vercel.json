{
  "version": 2,
  "buildCommand": "npm install && cd travel-website/client && npm install && npm run build",
  "outputDirectory": "travel-website/client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}